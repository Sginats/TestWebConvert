DATABASE_URL="postgresql://user:password@localhost:5432/fileforge?schema=public"
REDIS_URL="redis://localhost:6379"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-generate-secret-here"

STORAGE_DIR="./storage"
MOCK_PAYMENTS=true

# R2 / S3 Storage (Required for Vercel)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET=

# Optional Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=